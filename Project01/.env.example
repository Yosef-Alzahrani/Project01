# Frontend (Vite)
# Use Vite proxy by default (VITE_API_BASE_URL empty) OR set it explicitly.
VITE_API_BASE_URL=
# Set true to force offline mock AI mode.
VITE_USE_MOCK=false

# Real model (browser ONNX inference)
# Put your model at: public/models/wound_classifier.onnx
VITE_USE_LOCAL_ONNX=false
VITE_ONNX_MODEL_URL=/models/wound_classifier.onnx
VITE_MODEL_VERSION=onnx-local

# Backend (Node/Express)
PORT=5000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DB_PATH=server/data/app.sqlite
# IMPORTANT: change this in real deployments
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
